{
  "name": "ai-content-distribution-os",
  "version": "0.1.0",
  "description": "A Creator Operating System for managing the entire content lifecycle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db seed",
    "worker:publish": "tsx src/workers/publish-worker.ts",
    "worker:analytics": "tsx src/workers/analytics-worker.ts",
    "worker:ai": "tsx src/workers/ai-worker.ts",
    "worker:notifications": "tsx src/workers/notification-worker.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "date-fns": "^3.6.0",
    "openai": "^4.50.0",
    "@google/generative-ai": "^0.15.0",
    "@anthropic-ai/sdk": "^0.25.0",
    "stripe": "^16.0.0",
    "sharp": "^0.33.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "nanoid": "^5.0.7",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0",
    "eslint": "^9.7.0",
    "@types/node": "^22.0.0",
    "tsconfig-paths": "^4.2.0",
    "supabase": "^1.190.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
